{
  "name": "rs3-pvm-rotation",
  "version": "2.0.0",
  "description": "RS3 PvM Rotation Overlay - Real-time skill rotation tracker",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "start": "electron .",
    "package": "vite build && electron-packager . \"RS3 Rotation\" --platform=win32 --arch=x64 --icon=assets/icon.png --out=dist --overwrite --ignore=\"src|node_modules/.vite\""
  },
  "keywords": [
    "runescape",
    "rs3",
    "pvm",
    "rotation",
    "overlay"
  ],
  "author": "RS3 Overlay",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-packager": "^17.1.2",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uiohook-napi": "^1.5.4"
  }
}