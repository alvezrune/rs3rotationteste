{
  "name": "rs3-pvm-rotation",
  "version": "2.0.0",
  "description": "RS3 PvM Rotation Overlay - Real-time skill rotation tracker",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "start": "electron .",
    "dist": "vite build && electron-builder",
    "release": "vite build && electron-builder --publish always"
  },
  "keywords": [
    "runescape",
    "rs3",
    "pvm",
    "rotation",
    "overlay"
  ],
  "author": "RS3 Overlay",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-packager": "^17.1.2",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "lodash": "^4.17.23",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uiohook-napi": "^1.5.4"
  },
  "build": {
    "appId": "com.rs3rotation.overlay",
    "productName": "RS3 Rotation",
    "directories": {
      "output": "dist-release"
    },
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "files": [
      "dist-vite/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      "assets/**/*",
      "data/**/*"
    ],
    "publish": {
      "provider": "github"
    }
  }
}
